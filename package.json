{
  "name": "@radiant-core/radiantjs",
  "description": "Javascript library for Radiant Blockchain (RXD)",
  "version": "2.0.6",
  "author": "Radiant Core Developers <info@radiantcore.org>",
  "main": "index.js",
  "types": "radiant.d.ts",
  "scripts": {
    "lint": "standard",
    "lint_test": "standard && mocha",
    "test": "mocha",
    "radiant": "mocha --grep=\"radiant\"",
    "exact_match": "mocha --grep=\"exact_match\"",
    "coverage": "nyc --reporter=text npm run test",
    "build-radiant": "webpack --config webpack.config.js",
    "build-ecies": "webpack --config webpack.ecies.config.js",
    "build-message": "webpack --config webpack.message.config.js",
    "build-mnemonic": "webpack --config webpack.mnemonic.config.js",
    "build": "npm run build-radiant && npm run build-ecies && npm run build-message && npm run build-mnemonic",
    "prepublishOnly": "npm run build"
  },
  "unpkg": "radiant.min.js",
  "keywords": [
    "radiant",
    "radiant-blockchain",
    "transaction",
    "address",
    "p2p",
    "ecies",
    "cryptocurrency",
    "blockchain",
    "payment"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Radiant-Core/radiantjs"
  },
  "browser": {
    "request": "browser-request"
  },
  "dependencies": {
    "@noble/hashes": "^1.5.0",
    "@noble/secp256k1": "^3.1.0",
    "aes-js": "^3.1.2",
    "bn.js": "^4.12.3",
    "bs58": "=4.0.1",
    "buffer": "^6.0.3",
    "cbor-x": "^1.6.4",
    "clone-deep": "^4.0.1",
    "hash.js": "^1.1.7",
    "inherits": "2.0.3",
    "js-sha512": "^0.8.0",
    "unorm": "1.4.1"
  },
  "devDependencies": {
    "assert": "^2.1.0",
    "chai": "^4.5.0",
    "mocha": "^11.0.0",
    "nyc": "^17.1.0",
    "sinon": "^19.0.2",
    "standard": "^17.1.2",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "license": "MIT",
  "standard": {
    "globals": [
      "afterEach",
      "beforeEach",
      "describe",
      "it"
    ],
    "ignore": [
      "dist/**"
    ]
  }
}
